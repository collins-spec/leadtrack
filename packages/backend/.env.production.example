# Database (Railway will auto-populate DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/database

# Server
NODE_ENV=production
PORT=4000
BACKEND_URL=https://your-backend.railway.app
FRONTEND_URL=https://leadtrack.yourdomain.com

# JWT Secret (MUST be at least 32 characters - generate a strong random string)
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WEBHOOK_BASE_URL=https://your-backend.railway.app

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key

# Google Ads API
GOOGLE_ADS_CLIENT_ID=your-google-ads-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your-google-ads-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token

# Optional: Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
